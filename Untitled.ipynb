    "def wyswietl_sale(sala):\n",
    "    print(\"\\n  1 2 3 4 5\") # Numery kolumn\n",
    "    for i, rzad in enumerate(sala):\n",
    "        print(f\"{i+1} {' '.join(rzad)}\") # Numer rzędu + miejsca"
   ]
  },
